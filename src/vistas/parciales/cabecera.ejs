<header id="cabecera-portal">
  <div class="cabecera-inicio">
    <button id="btn-menu-movil" class="btn-menu-movil" title="Abrir menú" aria-label="Abrir menú">
      <svg viewBox="0 0 24 24"><path d="M3 6h18v2H3V6zm0 5h18v2H3v-2zm0 5h18v2H3v-2z"/></svg>
    </button>
    <div class="saludo-usuario">
      <h2 id="cabecera-nombre-cliente">Cargando...</h2>
      <span id="cabecera-numero-cliente">Cliente N° ...</span>
    </div>
  </div>
  <div class="cabecera-acciones">
    <div class="notif-contenedor">
      <div id="campana-notificaciones" class="cabecera-notificaciones" title="Notificaciones">
        <svg viewBox="0 0 24 24"><path d="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.89 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"/></svg>
      </div>
      <div id="panel-notificaciones" class="panel-notificaciones">
        <div class="panel-notif-cabecera">
          <span>Notificaciones</span>
          <span id="panel-notif-contador" class="panel-notif-contador">0 nuevas</span>
        </div>
        <div id="panel-notif-lista" class="panel-notif-lista"></div>
      </div>
    </div>
    <div class="cabecera-perfil">
      <div id="avatar-iniciales" class="avatar-cliente">--</div>
      <button id="btn-cerrar-sesion" class="btn-enlace">Cerrar sesión</button>
    </div>
  </div>
</header>
