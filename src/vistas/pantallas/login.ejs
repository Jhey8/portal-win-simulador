<section id="inicio-sesion" class="vista-pantalla activa">
  <div class="pantalla-login">
    <div class="login-banner">
      <div class="login-banner-marca">
        <span class="login-logo-win">win</span>
        <span class="login-logo-sub">INTERNET</span>
      </div>

      <div class="login-banner-contenido">
        <h1>Bienvenido a tu portal de autogestión</h1>
        <p>Gestiona tus servicios, pagos, reclamos y solicitudes de forma rápida, segura y 100% digital.</p>

        <ul class="login-beneficios">
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Consulta y paga tus recibos en línea
          </li>
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Solicita la baja de tu servicio en minutos
          </li>
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Haz seguimiento de tus trámites en tiempo real
          </li>
        </ul>
      </div>

      <div class="login-banner-grafico">
        <img src="/imagenes/pareja_banner.png" alt="Pareja feliz usando internet de WIN">
      </div>

      <div class="grafico-circulo-decorativo"></div>
      <div class="login-banner-decoracion-patron"></div>
    </div>
    <div class="login-formulario-seccion">
      <div class="login-caja">
        <h2>Inicia sesión</h2>
        <p class="login-subtitulo">Ingresa tus datos para continuar</p>

        <div id="error-login" class="alerta alerta-advertencia" style="display: none; margin-bottom: 20px;">
          Credenciales incorrectas.
        </div>

        <form id="form-login" class="login-formulario">
          <div class="grupo-formulario">
            <label for="login-numero-cliente">Número de cliente</label>
            <div class="control-con-icono">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
              </svg>
              <input type="text" id="login-numero-cliente" class="control-form-login control-formulario"
                placeholder="Ej. 73193206" required value="73193206">
            </div>
          </div>
          <div class="grupo-formulario">
            <label for="login-contrasena">Contraseña</label>
            <div class="control-con-icono">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
              </svg>
              <input type="password" id="login-contrasena" class="control-form-login control-formulario"
                placeholder="Tu contraseña" required value="MRjhey10">
            </div>
          </div>
          <button type="submit" class="btn btn-primario" style="margin-top: 10px; height: 50px;">Ingresar</button>
        </form>

        <div class="login-enlaces-bajos">
          <a href="#">¿Olvidaste tus datos?</a>
          <div style="margin-top: 15px; color: var(--gris-texto-secundario); font-size:13px;">
            ¿Aún no tienes cuenta? <a href="#" id="ir-a-registro" class="btn-enlace">Crear una cuenta</a>
          </div>
        </div>

        <a href="/admin" class="login-acceso-admin">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
          Acceso para asesores &middot; Panel de administración
        </a>
      </div>
    </div>
  </div>
</section>