<section id="registro" class="vista-pantalla">
  <div class="pantalla-login">
    <div class="login-banner">
      <div class="login-banner-marca">
        <span class="login-logo-win">win</span>
        <span class="login-logo-sub">INTERNET</span>
      </div>

      <div class="login-banner-contenido">
        <h1>Únete a WIN Internet</h1>
        <p>Crea tu cuenta para gestionar tus servicios, pagos y solicitudes desde un solo lugar, 100% en línea.</p>

        <ul class="login-beneficios">
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Acceso inmediato a tu portal de autogestión
          </li>
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Consulta tus recibos y paga en línea
          </li>
          <li>
            <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Solicita y sigue tus trámites 24/7
          </li>
        </ul>
      </div>

      <div class="login-banner-grafico">
        <img src="/imagenes/pareja_banner.png" alt="Pareja usando internet de WIN">
      </div>

      <div class="grafico-circulo-decorativo"></div>
      <div class="login-banner-decoracion-patron"></div>
    </div>
    <div class="login-formulario-seccion">
      <div class="login-caja">
        <h2>Crear cuenta</h2>
        <p class="login-subtitulo">Completa tus datos para registrarte</p>

        <div id="error-registro" class="alerta alerta-advertencia" style="display: none; margin-bottom: 20px;"></div>

        <form id="form-registro" class="login-formulario">
          <div class="grupo-formulario">
            <label for="registro-nombre">Nombre completo</label>
            <input type="text" id="registro-nombre" class="control-formulario" placeholder="Ej. Juan Pérez" required>
          </div>
          <div class="grupo-formulario" style="margin-top:14px;">
            <label for="registro-numero-cliente">Número de cliente</label>
            <input type="text" id="registro-numero-cliente" class="control-formulario campo-numerico" placeholder="Entre 6 y 12 dígitos" required inputmode="numeric" maxlength="12" autocomplete="off">
          </div>
          <div class="grupo-formulario" style="margin-top:14px;">
            <label for="registro-dni">DNI</label>
            <input type="text" id="registro-dni" class="control-formulario campo-numerico" placeholder="8 dígitos" required inputmode="numeric" maxlength="8" autocomplete="off">
          </div>
          <div class="grupo-formulario" style="margin-top:14px;">
            <label for="registro-correo">Correo electrónico</label>
            <input type="email" id="registro-correo" class="control-formulario" placeholder="tucorreo@ejemplo.com">
          </div>
          <div class="grupo-formulario" style="margin-top:14px;">
            <label for="registro-telefono">Teléfono</label>
            <input type="text" id="registro-telefono" class="control-formulario campo-numerico" placeholder="9 dígitos (ej. 987654321)" inputmode="numeric" maxlength="9" autocomplete="off">
          </div>
          <div class="grupo-formulario" style="margin-top:14px;">
            <label for="registro-contrasena">Contraseña</label>
            <input type="password" id="registro-contrasena" class="control-formulario" placeholder="Mínimo 6 caracteres" required>
          </div>
          <div class="grupo-formulario" style="margin-top:14px;">
            <label for="registro-contrasena2">Confirmar contraseña</label>
            <input type="password" id="registro-contrasena2" class="control-formulario" placeholder="Repite tu contraseña" required>
          </div>

          <button type="submit" class="btn btn-primario" style="margin-top: 20px; height: 50px; width:100%;">Crear cuenta</button>
        </form>

        <div class="login-enlaces-bajos" style="margin-top:18px;">
          ¿Ya tienes cuenta? <a href="#" id="ir-a-login" class="btn-enlace">Inicia sesión</a>
        </div>
      </div>
    </div>
  </div>
</section>
