# Copia este archivo como ".env" y ajusta los valores segun tu entorno.

# Puerto del servidor (en la nube el hosting suele definir PORT automaticamente)
PUERTO=3005

# --- Base de datos MySQL ---
# En LOCAL (XAMPP): host localhost, usuario root, sin contrasena.
# En la NUBE: usa los datos que te da tu proveedor de MySQL (Aiven, TiDB, etc.)
BD_HOST=localhost
BD_PUERTO=3306
BD_USUARIO=root
BD_CONTRASENA=
BD_NOMBRE=portal_win

# Pon "true" si tu base de datos en la nube requiere conexion segura SSL
# (Aiven, TiDB y la mayoria de proveedores lo requieren). En local dejalo en false.
BD_SSL=false
